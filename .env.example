# ============================================
# SENTINELEDGE - Local Security Monitoring System
# ============================================

# Database Configuration
POSTGRES_DB=sentineledge
POSTGRES_USER=sentineledge_user
POSTGRES_PASSWORD=sentineledge_secure_pass_2024
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# Backend Configuration
BACKEND_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars-here-please
ACCESS_TOKEN_EXPIRE_MINUTES=480
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@sentineledge.local
BOOTSTRAP_ADMIN_PASSWORD=admin
DEMO_MODE=true
ALLOW_LOCAL_VIDEO_SOURCES=true
ENABLE_EXTERNAL_INTEGRATIONS=false
DEBUG=false

# Frontend Configuration
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# Telegram Notifications (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Engine Configuration
AI_ENGINE_ENABLED=false
DETECTION_CONFIDENCE_THRESHOLD=0.5
DETECTION_NMS_THRESHOLD=0.4
MAX_FPS=30

# Redis URL used by backend health checks in local/dev mode
REDIS_URL=redis://localhost:6379/0

# Camera Configuration (Examples - Manage via Admin Panel)
# CAMERA_1_NAME=Entrada Principal
# CAMERA_1_RTSP=rtsp://admin:password@192.168.1.100:554/stream
# CAMERA_2_NAME=Zona de Carga
# CAMERA_2_RTSP=rtsp://admin:password@192.168.1.101:554/stream

# ============================================
# Security Notes:
# 1. Never commit this file with real credentials
# 2. Use strong passwords (min 16 chars)
# 3. Change SECRET_KEY before production
# 4. Keep camera passwords encrypted in DB
# ============================================
